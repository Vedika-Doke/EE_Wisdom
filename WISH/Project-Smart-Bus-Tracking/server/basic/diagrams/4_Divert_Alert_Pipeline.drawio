<mxfile host="app.diagrams.net" modified="2026-06-07T00:00:00.000Z" agent="Mozilla/5.0" version="24.6.4" type="device">
  <diagram name="Divert Alert Pipeline" id="divert">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Divert-Alert Pipeline (Person 2 -&gt; Person 3 IVR/SMS + Authority)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1F2E5C;" vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="trigger" value="ETA Engine (Person 2)&#10;OFF_ROUTE fired&#10;(K = 3 consecutive packets δ &gt; W)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="alert_row" value="INSERT INTO Alerts&#10;(Bus_ID, Alert_Type='ROUTE_DIVERT',&#10; Status='OPEN', Timestamp=now)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="notify" value="POST /notify (Person 3 dispatcher)&#10;&#10;{&#10;  event: ROUTE_DIVERT,&#10;  bus_id: BUS_17,&#10;  last_known: {lat, lon},&#10;  off_by_m: 142,&#10;  template: DIVERT,&#10;  audience: queriers_last_90min&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="200" width="280" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="banner" value="POST /authority/banner&#10;(WebSocket/SSE live banner)&#10;'BUS_17 diverted 142 m off route'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="200" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="db_alerts" value="DB · Alerts table (Person 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dispatcher" value="Person 3 — Notification Dispatcher&#10;&#10;SELECT phone, language, channel&#10;FROM queries&#10;WHERE bus_id = 'BUS_17'&#10;  AND ts &gt;= now − 90 min&#10;  AND notified = false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=left;spacingLeft=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="400" width="360" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="authdash" value="Authority Dashboard&#10;(banner pops up, dispatcher ACKs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="310" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="render" value="Render template in user's language&#10;DIVERT: 'Bus {bus_id} has diverted from its route.&#10;Please wait for another bus or move to {alt_stop}.'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="560" width="360" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fanout" value="Fan-out per querier" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="465" y="670" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sms" value="SMS API&#10;(any basic phone)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="760" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ivr" value="IVR outbound call (Exotel)&#10;'Bus 17 has been diverted...'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="760" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="display" value="Display board update&#10;'BUS 17 — DIVERTED'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5C26B;strokeColor=#A8741C;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="760" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="markdone" value="UPDATE queries SET notified = true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E8E8;strokeColor=#666666;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="455" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="trigger" target="alert_row"><mxGeometry relative="1" as="geometry"/></mxCell>
