        <mxCell id="seg2" style="endArrow=none;html=1;strokeColor=#2E5C8A;strokeWidth=3;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="seg3" style="endArrow=none;html=1;strokeColor=#2E5C8A;strokeWidth=3;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>
