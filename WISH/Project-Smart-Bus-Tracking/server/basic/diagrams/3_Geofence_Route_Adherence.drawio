        <mxCell id="perp" value="δ (cross-track)" style="endArrow=classic;html=1;strokeColor=#B85450;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#B85450;" edge="1" parent="1" source="bus" target="busproj"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wlabel" value="W (corridor half-width, e.g. 50 m)" style="text;html=1;align=left;fontSize=11;fontStyle=2;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="55" y="430" width="280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="buslabel" value="Bus position B(φ_B, λ_B)" style="text;html=1;align=left;fontSize=11;fontStyle=2;fontColor=#A8741C;" vertex="1" parent="1">
          <mxGeometry x="290" y="380" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="onroute_rule" value="on_route(B)  ⇔  min over segments  δ_i(B)  ≤  W" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="455" width="470" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="eqbox" value="EQUATIONS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#888888;fontSize=13;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="560" y="70" width="500" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="hav" value="HAVERSINE (point distance)&#10;&#10;a = sin²((φ₂−φ₁)/2) + cos φ₁ · cos φ₂ · sin²((λ₂−λ₁)/2)&#10;c = 2 · atan2(√a, √(1−a))&#10;d = R · c          (R = 6 371 000 m)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="105" width="460" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="bear" value="BEARING&#10;&#10;θ = atan2( sin(Δλ)·cos φ₂ ,&#10;           cos φ₁·sin φ₂ − sin φ₁·cos φ₂·cos(Δλ) )" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="205" width="460" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="xt" value="CROSS-TRACK (perp distance, bus to segment)&#10;&#10;δ_xt = asin( sin(d_iB / R) · sin(θ_iB − θ_i,i+1) ) · R" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="290" width="460" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="fast" value="EQUIRECTANGULAR FAST-PATH (recommended at our scale)&#10;&#10;x = R · (λ − λ₀) · cos φ₀&#10;y = R · (φ − φ₀)&#10;t* = clip( (B − P_i)·(P_{i+1} − P_i) / ‖P_{i+1} − P_i‖² , 0 , 1 )&#10;δ = ‖B − ( P_i + t*·(P_{i+1} − P_i) )‖" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="370" width="460" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="rules" value="ROUTE-ADHERENCE RULES" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#888888;fontSize=13;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="1020" height="270" as="geometry"/>
        </mxCell>
        <mxCell id="r1" value="ARRIVED(P_j)  ⇔  haversine(B, P_j) ≤ r_j  ∧  v &lt; 2 m/s&#10;(r_j = 30 m default; larger at terminals)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="480" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="DEPARTED(P_j)  ⇔  haversine(B, P_j) &gt; r_j + 20 m  ∧  v &gt; 3 m/s&#10;(20 m hysteresis prevents flicker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="560" width="480" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="OFF_ROUTE fires after K = 3 consecutive packets with δ &gt; W&#10;(at T_pkt = 150 s -&gt; alert latency ≈ 7.5 min ; suppresses single-sample GPS spikes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="980" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="On OFF_ROUTE  -&gt;  insert into Alerts(Alert_Type='ROUTE_DIVERT')&#10;                -&gt;  POST /notify to Person 3 dispatcher (audience = queriers_last_90min)&#10;                -&gt;  POST /authority/banner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="720" width="980" height="60" as="geometry"/>
        </mxCell>
      </root>
