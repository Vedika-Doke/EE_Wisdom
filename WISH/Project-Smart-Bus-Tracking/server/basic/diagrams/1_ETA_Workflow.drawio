          <mxGeometry x="350" y="600" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="learn" value="ONLINE LEARNING&#10;T_obs = ts − seg_start_ts&#10;τ_k(b) ← α·T_obs + (1−α)·τ_k(b)&#10;Update d_j(b) if dwelled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="600" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="computeETA" value="COMPUTE ETA per downstream stop P_m&#10;&#10;ETA(P_m) = (L_k − s_k)/L_k · τ_k(b)&#10;          + Σ τ_i(b)  for i = k+1..m−1&#10;          + Σ d_j(b)  for j = k+1..m−1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1">
